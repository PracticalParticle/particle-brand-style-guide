{
  "name": "@particle-crypto/style-guide",
  "version": "1.0.0",
  "description": "Design system and style guide for Particle Crypto Security LTD - BloxChain Protocol",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "build:app": "tsc && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:a11y": "node test-a11y.js",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.0",
    "clsx": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-to-print": "^3.3.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.15.0",
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-interactions": "^8.6.17",
    "@storybook/addon-links": "^8.6.17",
    "@storybook/blocks": "^8.6.17",
    "@storybook/react": "^8.6.17",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "@storybook/test-runner": "^0.20.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.10.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "eslint-plugin-storybook": "^0.11.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.47",
    "storybook": "^8.6.17",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "design-system",
    "style-guide",
    "component-library",
    "react",
    "typescript",
    "tailwindcss",
    "blockchain",
    "enterprise"
  ],
  "author": "Particle Crypto Security LTD",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/globals.css",
    "./styles.css": "./src/styles/globals.css",
    "./tailwind-preset": "./tailwind.preset.js"
  },
  "files": [
    "dist",
    "src/styles",
    "tailwind.preset.js"
  ]
}
